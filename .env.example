# 77Imóveis — variáveis de ambiente (copie para .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
NEXT_PUBLIC_SITE_URL=https://77imoveis.com.br
NEXT_PUBLIC_MAPTILER_KEY=sua-chave-maptiler
# Container do Google Tag Manager (formato GTM-XXXXXXX). O Measurement ID do
# GA4 (G-XXXXXXX) NÃO vai aqui — ele é configurado dentro do próprio GTM,
# na tag "Configuração do GA4".
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ANALYTICS_DEBUG=false

# Só no servidor / Edge Functions (NUNCA expor no navegador)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
PAYMENT_PROVIDER=stripe
# Stripe (live). A Secret key fica só no servidor. O Webhook secret vem do
# endpoint criado em Dashboard > Developers > Webhooks (https://.../api/webhooks/stripe).
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
TURNSTILE_SITE_KEY=chave-publica-turnstile
TURNSTILE_SECRET_KEY=chave-secreta-turnstile

# E-mail de leads (Resend) — NÃO vai no .env do Next.js: é secret da Edge
# Function `send-lead-email` no Supabase (Project Settings > Edge Functions >
# Secrets, ou `supabase secrets set`). Ver database/25_lead_email_notifications.sql.
# RESEND_API_KEY=
# LEADS_WEBHOOK_SECRET=  # tem que ser igual ao valor salvo em vault.secrets

# GitHub Actions (deploy Hostinger) -> usar como Secrets
HOSTINGER_FTP_HOST=
HOSTINGER_FTP_USER=
HOSTINGER_FTP_PASS=
