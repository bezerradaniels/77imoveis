{
  "name": "77imoveis",
  "version": "0.1.0",
  "private": true,
  "description": "Portal imobiliário regional do DDD 77 (Bahia)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:types": "supabase gen types typescript --linked > lib/supabase/types.ts",
    "migrate:images:webp": "vite-node scripts/migrate-images-webp.ts",
    "rollback:images:webp": "vite-node scripts/rollback-images-webp.ts",
    "cleanup:old-images": "vite-node scripts/cleanup-old-images.ts"
  },
  "browserslist": [
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 111",
    "Safari >= 16.4",
    "ios_saf >= 16.4"
  ],
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
